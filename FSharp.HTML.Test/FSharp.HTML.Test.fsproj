        <PackageReference Include="FSharp.xUnit" Version="1.3.0" />
        <PackageReference Include="xunit.v3.core.mtp-v2" Version="3.2.2" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\FSharp.HTML\FSharp.HTML.fsproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Update="FSharp.Core" Version="10.1.201" />
    </ItemGroup>

