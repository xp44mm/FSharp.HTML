        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Dir.fs" />
        <Compile Include="RenderTest.fs" />
        <Compile Include="BrRemoverTest.fs" />
        <Compile Include="AttributeTest.fs" />
